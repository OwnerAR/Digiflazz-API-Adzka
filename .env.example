APP_ENV=development
SERVER_PORT=8080

# SQLite
SQLITE_DSN=file:digiflazz.db?_busy_timeout=5000&_fk=1

# OtomaX API
OTOMAX_API_BASE_URL=http://localhost:8080/api
OTOMAX_APP_ID=OtomaX.Addon
OTOMAX_APP_KEY=demoKey
OTOMAX_DEV_KEY=YAR.OtomaX.OpenApi.App
# Format pesan InsertInbox: placeholder {{ref_id}}, {{hp}}, {{pulsa_code}}, {{price}}, {{username}}, {{commands}}
# Contoh: {{pulsa_code}}.{{hp}}.{{price}}.{{ref_id}} agar sesuai format OtomaX
OTOMAX_INSERTINBOX_PESAN_FORMAT={{pulsa_code}}.{{hp}}.{{price}}.{{ref_id}}

# MSSQL OtomaX (optional, hanya untuk sinkronisasi produk)
OTOMAX_MSSQL_DSN=
OTOMAX_KODE_MODUL=DFLZ
OTOMAX_CALLBACK_URL=

# Security
ALLOWED_SOURCE_IPS=127.0.0.1
OTOMAX_SIGNATURE_SECRET=changeme-otomax

# Pricing
DEFAULT_ADMIN_FEE=0
DEFAULT_MARGIN=0


# HTTP
REQUEST_TIMEOUT_MS=15000
# Callback timeout khusus untuk callback ke OtomaX (default: 30 detik)
# Dapat disesuaikan jika server OtomaX membutuhkan waktu lebih lama untuk merespons
CALLBACK_TIMEOUT_MS=30000

# Digiflazz
DIGIFLAZZ_BASE_URL=https://api.digiflazz.com
DIGIFLAZZ_USERNAME=
DIGIFLAZZ_API_KEY=
DIGIFLAZZ_SIGNATURE_SECRET=

# Schedulers
PRODUCT_SYNC_ENABLED=false
PRODUCT_SYNC_INTERVAL_MINUTES=60

# Mockup/Testing Mode
# Set to true to use mockup data instead of real Digiflazz API calls
# When enabled, DIGIFLAZZ_* configs are optional
MOCKUP_MODE=false
# When false, prepaid sync updates only parsing table and skips updating produk prices
UPDATE_PRODUCT_PRICE=false

